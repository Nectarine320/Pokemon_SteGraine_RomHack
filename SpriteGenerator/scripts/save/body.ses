// To be run when the body workspace is the active project
() {
    ~ string GENERIC_FP = "./generic-with-csv.ses";

    ~ string[] IDs = [
        "default-male", "default-female"
    ];

    ~ script generic = $SE.read_script(GENERIC_FP);
    generic.run(IDs, new {string:int}, "body", 
            $SE.get_project().get_layer("body"));
}
