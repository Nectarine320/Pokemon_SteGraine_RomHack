// To be run when the clothes workspace is the active project
() {
    ~ string[] TOPS = [ "t-shirt" ];
    ~ string[] BOTTOMS = [ "pants" ];
    ~ string[] SHOES = [ "simple" ];
    ~ string[] OUTFITS = [ "gi", "dress-with-apron" ];

    ~ {string:int} MAP = {
        "gi" : 2, 
        "dress-with-apron" : 2
    };

    ~ int start_bottoms = #| TOPS;
    ~ int start_shoes = start_bottoms + (#| BOTTOMS)
    ~ int start_outfits = start_shoes + (#| SHOES);
    ~ int to_save = start_outfits + (#| OUTFITS);

    project clothes_workspace = $SE.get_project();
    layer clothes_layer = clothes_workspace.get_layer("clothes");

    save_category(clothes_layer, TOPS, MAP, 0, "top");
    save_category(clothes_layer, BOTTOMS, MAP, start_bottoms, "bottom");
    save_category(clothes_layer, SHOES, MAP, start_shoes, "shoes");
    save_category(clothes_layer, OUTFITS, MAP, start_outfits, "outfit");
}

save_category(~ layer l, ~ string[] IDs, ~ {string:int} MAP, 
        ~ int cel_offset, ~ string category) {
    ~ int to_save = #| IDs;
    string csv = "";

    for (int i = 0; i < to_save; i++) {
        ~ string id = IDs[i];
        save_article(l, cel_offset + i, id, category);

        csv += csv_entry(id, MAP) + (i + 1 < to_save ? "," : "\n");
    }

    for (prefix in size_prefixes())
        save_csv(csv, prefix + "-" + category);
}

csv_entry(~ string id, ~ {string:int} MAP -> string) -> 
        id + ":" + (MAP.has(id) ? MAP.lookup(id) : 1)

save_csv(~ string csv, ~ string folder) {
    write_file("../../bases/" + folder + "/" + folder + ".csv", csv);
}

save_article(~ layer clothes_layer, ~ int i, ~ string id, ~ string article) {
    ~ image content = clothes_layer.get_cel(i);

    for (prefix in size_prefixes())
        save_size(content, id, article, prefix);
}

size_prefixes(-> string[]) -> [ "dm", "df" ]

save_size(~ image content, ~ string id, ~ string article, ~ string prefix) {
    image anim = animate(content, prefix);

    ~ string art_folder = "../../bases/" + prefix + "-" + article + "/";
    
    write_image(art_folder + id + ".png", anim);
}

animate(~ image source, ~ string prefix -> image) {
    ~ string FOLDER = "../../workspaces/";
    ~ image MAP = read_image(FOLDER + "t-body-map.png");
    ~ image ANIM = read_image(FOLDER + prefix + "-anim-mapping.png");

    return $Graphics.uv_mapping(source, MAP, ANIM);
}
