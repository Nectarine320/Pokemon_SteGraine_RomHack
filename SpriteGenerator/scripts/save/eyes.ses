// To be run when the eyes workspace is the active project
() {
    ~ string GENERIC_FP = "./generic-with-csv.ses";

    ~ string[] IDs = [
        "default", "bushy", "drowsy", "intense", "pointed", "wise", "beady", 
        "sunglasses"
    ];

    ~ script generic = $SE.read_script(GENERIC_FP);
    generic.run(IDs, new {string:int}, "eyes", 
            $SE.get_project().get_layer("eyes"));
}
