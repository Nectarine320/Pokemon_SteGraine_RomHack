// To be run when the hat workspace is the active project
// TODO - add cat ears + other ear headbands
() {
    ~ string GENERIC_FP = "./generic.ses";
    ~ string GEN_W_CSV_FP = "./generic-with-csv.ses";
    
    ~ string[] IDs = [
        "yakyu-cap", "adventure", "hiking-hat", "captain", "chef", 
        "gateperson", "bandana", "knit-cap", "bike-helmet", "top-hat", 
        "brimmed-beret", "angler-cap"
    ];
    ~ {string:int} MAP = {
        "yakyu-cap" : 2, 
        "adventure" : 2, 
        "captain" : 3, 
        "gateperson" : 2, 
        "bandana" : 2, 
        "knit-cap" : 3, 
        "bike-helmet" : 2, 
        "top-hat" : 2, 
        "angler-cap" : 3
    };

    for (id in IDs)
        if (!MAP.has(id)) MAP.define(id, 1);

    ~ script generic = $SE.read_script(GENERIC_FP);
    ~ script gwcsv = $SE.read_script(GEN_W_CSV_FP);
    ~ project p = $SE.get_project();

    gwcsv.run(IDs, MAP, "hat", p.get_layer("hat"));
    generic.run(IDs, "hat-back", p.get_layer("hat-back"));
    generic.run(IDs, "hat-mask", p.get_layer("mask"));
    generic.run(IDs, "hat-back-mask", p.get_layer("mask-back"));
}
