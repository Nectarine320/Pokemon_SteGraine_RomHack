// To be run when the head workspace is the active project
() {
    ~ string GENERIC_FP = "./generic-with-csv.ses";

    ~ string[] IDs = [
        "standard-head", "small-head", "square-jaw"
    ];

    ~ script generic = $SE.read_script(GENERIC_FP);
    generic.run(IDs, new {string:int}, "head", 
            $SE.get_project().get_layer("head"));
}
