// To be run when the capsule workspace is the active project
() {
    ~ string LAYER_ID = "pokeball";
    
    ~ string GENERIC_FP = "./generic.ses";
    ~ string GEN_W_CSV_FP = "./generic-with-csv.ses";
    
    ~ string[] IDs = [
        "default"
    ];
    ~ {string:int} MAP = new {string:int}; /*{
        "yakyu-cap" : 2, 
        "adventure" : 2, 
        "captain" : 3, 
        "gateperson" : 2, 
        "bandana" : 2, 
        "knit-cap" : 3, 
        "bike-helmet" : 2, 
        "top-hat" : 2, 
        "angler-cap" : 3
    };*/

    for (id in IDs)
        if (!MAP.has(id)) MAP.define(id, 2);

    ~ script generic = $SE.read_script(GENERIC_FP);
    ~ script gwcsv = $SE.read_script(GEN_W_CSV_FP);
    ~ project p = $SE.get_project();

    gwcsv.run(IDs, MAP, LAYER_ID, p.get_layer(LAYER_ID));
}
